---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
---

<BaseLayout
  title="Nyhetsbrev: veckans bästa fiskespots"
  description="Prenumerera på Strömkasts nyhetsbrev och få veckans bästa fiskespots, nyheter och guider direkt i din inbox."
  pageType="newsletter"
>
  <div class="pt-28 pb-20 px-4 sm:px-6 max-w-lg mx-auto text-center">
    <p class="text-stone text-sm font-medium uppercase tracking-wider mb-3">Nyhetsbrev</p>
    <h1 class="font-display text-4xl font-bold text-deep mb-4">Fiskenytt varje vecka</h1>
    <p class="text-stone text-lg leading-relaxed mb-12">Varje torsdag: veckans bästa fiskespots, säsongsuppdateringar och redaktionella guider. Gratis och reklamfritt.</p>
    <NewsletterForm placement="footer" heading="Anmäl dig idag" subheading="Avregistrera när du vill. Inga spammail." />
  </div>
</BaseLayout>
